<settings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">
    <setting propertyKey="@Properties.SecondsMode" title="@Strings.SecondsModeTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.SecondsModeOff</listEntry>
            <listEntry value="1">@Strings.SecondsModeOn</listEntry>
            <listEntry value="2">@Strings.SecondsModeWristTurn</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.ShowLeadingHourZero" title="@Strings.ShowLeadingHourZeroTitle">
        <settingConfig type="boolean" />
    </setting>

    <setting propertyKey="@Properties.ShowSubtleBatteryIndicator" title="@Strings.ShowSubtleBatteryIndicatorTitle">
        <settingConfig type="boolean" />
    </setting>

    <setting propertyKey="@Properties.BackgroundMode" title="@Strings.BackgroundModeTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.BackgroundModeDay</listEntry>
            <listEntry value="1">@Strings.BackgroundModeNight</listEntry>
            <listEntry value="2">@Strings.BackgroundModeAuto</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.DataFieldBelowTime" title="@Strings.DataFieldBelowTimeTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.DataFieldBelowTimeDate</listEntry>
            <listEntry value="1">@Strings.DataFieldOptionAltitude</listEntry>
            <listEntry value="2">@Strings.DataFieldOptionHeartRate</listEntry>
            <listEntry value="3">@Strings.DataFieldOptionBattery</listEntry>
            <listEntry value="4">@Strings.DataFieldOptionSteps</listEntry>
            <listEntry value="5">@Strings.DataFieldOptionNotifications</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.InsetDataField1" title="@Strings.InsetDataField1Title">
        <settingConfig type="list">
            <listEntry value="0">@Strings.DataFieldOptionAltitude</listEntry>
            <listEntry value="1">@Strings.DataFieldOptionHeartRate</listEntry>
            <listEntry value="2">@Strings.DataFieldOptionBattery</listEntry>
            <listEntry value="3">@Strings.DataFieldOptionSteps</listEntry>
            <listEntry value="4">@Strings.DataFieldOptionNotifications</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.InsetDataField2" title="@Strings.InsetDataField2Title">
        <settingConfig type="list">
            <listEntry value="0">@Strings.DataFieldOptionAltitude</listEntry>
            <listEntry value="1">@Strings.DataFieldOptionHeartRate</listEntry>
            <listEntry value="2">@Strings.DataFieldOptionBattery</listEntry>
            <listEntry value="3">@Strings.DataFieldOptionSteps</listEntry>
            <listEntry value="4">@Strings.DataFieldOptionNotifications</listEntry>
        </settingConfig>
    </setting>
</settings>
